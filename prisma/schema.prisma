generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AdminLevel {
  USER
  ADMIN
}

model user {
  id          String     @id @unique @default(uuid())
  name        String
  mail        String     @unique
  password    String
  admin_level AdminLevel @default(USER)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
